{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_sign_in": false,
  },
  "git_panel": {
    "dock": "left",
  },
  "window_decorations": "client",
  "when_closing_with_no_tabs": "keep_window_open",
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "buffer_line_height": { "custom": 1.4 },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Kanagawa Wave",
  },
  "icon_theme": "Catppuccin Frappé",
  "indent_guides": {
    "coloring": "indent_aware",
    "active_line_width": 2,
  },
  "project_panel": {
    "button": true,
    "dock": "left",
    "entry_spacing": "standard",
  },
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "fish",
        "args": ["--interactive"],
      },
    },
  },
  "file_types": {
    "Lume": ["lume"],
  },
  "lsp": {
    "biome": {
      "settings": {
        "config_path": "<path>/biome.json",
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
    "lua-language-server": {
      "binary": {
        "path": "lua-language-server",
      },
    },
  },
  "languages": {
    "HTML": {
      "tab_size": 2,
    },
    "lume": {
      "tab_size": 2,
      "language_servers": ["lume-lsp"],
    },
    "Nix": {
      "tab_size": 2,
    },
    "JavaScript": {
      "formatter": [
        { "language_server": { "name": "biome" } },
        { "code_action": "source.fixAll.biome" },
        { "code_action": "source.organizeImports.biome" },
      ],
    },
    "TypeScript": {
      "formatter": [
        { "language_server": { "name": "biome" } },
        { "code_action": "source.fixAll.biome" },
        { "code_action": "source.organizeImports.biome" },
      ],
    },
    "TSX": {
      "formatter": [
        { "language_server": { "name": "biome" } },
        { "code_action": "source.fixAll.biome" },
        { "code_action": "source.organizeImports.biome" },
      ],
    },
    "SCSS": {
      "tab_size": 2,
    },
    "Svelte": {
      "tab_size": 2,
    },
    "Jinja2": {
      "tab_size": 2,
    },
    "Fish": {
      "tab_size": 2,
    },
  },
  "ssh_connections": [
    {
      "host": "megumu",
      "projects": [
        {
          "paths": ["/home/kamov/nix"],
        },
      ],
    },
  ],
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "ollama",
      "model": "lfm2:24b",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
}
